{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "../../google-play-service-account.json",
        "track": "internal"
      }
    }
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "pnpm": "10.33.2"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "pnpm": "10.33.2"
    },
    "production": {
      "autoIncrement": true,
      "pnpm": "10.33.2",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://amana-api.fly.dev"
      }
    }
  }
}
