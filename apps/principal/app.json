{
  "expo": {
    "name": "Amana Principal",
    "slug": "amana-principal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C1E"
    },
    "ios": {
      "bundleIdentifier": "com.amana.principal",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "NFCReaderUsageDescription": "Used to pair with an agent device via NFC tap.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "TAG",
          "TAG"
        ]
      }
    },
    "android": {
      "package": "com.amana.principal",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1C1E"
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#222222"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9fff59a8-3468-4df6-b0d2-dad224af28d8"
      }
    },
    "owner": "alex77063"
  }
}
