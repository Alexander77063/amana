{
  "expo": {
    "name": "Amana Agent",
    "slug": "amana-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#222222"
    },
    "ios": {
      "bundleIdentifier": "com.amana.agent",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR codes and capture receipt photos.",
        "NSLocationWhenInUseUsageDescription": "Used to record the location of transactions.",
        "NFCReaderUsageDescription": "Used to pair with a principal device via NFC tap.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"]
      }
    },
    "android": {
      "package": "com.amana.agent",
      "versionCode": 1
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#222222"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d61177fe-f167-45f6-a5bd-25524aff563c"
      }
    },
    "owner": "alex77063"
  }
}
