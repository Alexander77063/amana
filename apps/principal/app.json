{
  "expo": {
    "name": "Amana Principal",
    "slug": "amana-principal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#222222"
    },
    "ios": {
      "bundleIdentifier": "com.amana.principal",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "NFCReaderUsageDescription": "Used to pair with an agent device via NFC tap."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"]
      }
    },
    "android": {
      "package": "com.amana.principal",
      "versionCode": 1
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        { "color": "#222222" }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9fff59a8-3468-4df6-b0d2-dad224af28d8"
      }
    },
    "owner": "alex77063"
  }
}
