{
  "name": "amana",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "argon2",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.1.3",
    "typescript": "5.5.4"
  }
}
