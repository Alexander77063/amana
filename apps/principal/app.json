{
  "expo": {
    "name": "Amana Principal",
    "slug": "amana-principal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "bundleIdentifier": "com.amana.principal",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "NFCReaderUsageDescription": "Used to pair with an agent device via NFC tap.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG", "TAG"]
      }
    },
    "android": {
      "package": "com.amana.principal",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      }
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#D97706"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9fff59a8-3468-4df6-b0d2-dad224af28d8"
      }
    },
    "owner": "alex77063"
  }
}
